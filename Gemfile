source "https://rubygems.org"

# GitHub Pages gem - bevat Jekyll en alle ondersteunde plugins
gem "github-pages", group: :jekyll_plugins

# Windows-specifieke dependency
gem 'wdm', '>= 0.1.0' if Gem.win_platform?

# Plugins (moeten ondersteund worden door github-pages)
group :jekyll_plugins do
  gem "jekyll-feed"
end
